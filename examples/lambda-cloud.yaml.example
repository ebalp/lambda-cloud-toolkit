# Lambda Cloud configuration for vLLM deployment
# Copy this file to lambda.yaml and fill in your values.
#
# Required env vars (set in .sync.env or environment):
#   LAMBDA_API_KEY - Lambda Cloud API key (Dashboard -> Settings -> API Keys)
#   HF_TOKEN       - Hugging Face token (for gated model downloads)

# SSH key registered in Lambda Cloud (Dashboard -> SSH Keys)
ssh_key_name: "my-lambda-key"
ssh_key_file: "~/.ssh/my-lambda-key.pem"

# Git repo to clone on the instance (used by --setup bootstrap)
repo_url: "https://github.com/your-org/your-repo.git"
# repo_dir: "/home/ubuntu/your-repo"  # derived from repo_url if omitted
# setup_script: "my-setup.sh"  # run after cloning repo (omit to skip)

defaults:
  vllm_port: 8000
  vllm_venv_path: /home/ubuntu/vllm-venv
  max_launch_retries: 5
  launch_retry_delay: 60
  readiness_timeout: 900  # 15 min for model download + load

# Per-model GPU and vLLM settings
# _default is used for any model not explicitly listed
instance_preferences:
  - gpu_1x_a100
  - gpu_1x_a100_sxm4

model_gpu_map:
  meta-llama/Llama-3.1-8B-Instruct:
    instance_type: gpu_1x_a10
    instance_preferences:
      - gpu_1x_a10
      - gpu_1x_a100
      - gpu_1x_a100_sxm4
    vllm_args: "--max-model-len 4096"
  meta-llama/Llama-3.3-70B-Instruct:
    instance_type: gpu_8x_a100
    instance_preferences:
      - gpu_8x_a100
      - gpu_8x_a100_sxm4
      - gpu_8x_a10
    vllm_args: "--tensor-parallel-size 8 --max-model-len 4096"
  Qwen/Qwen2.5-7B-Instruct:
    instance_type: gpu_1x_a10
    vllm_args: "--max-model-len 4096"
  openai/gpt-oss-20b:
    instance_type: gpu_1x_a100
    vllm_args: "--max-model-len 4096"
  _default:
    instance_type: gpu_1x_a100
    vllm_args: "--max-model-len 4096"
